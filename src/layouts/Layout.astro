---
interface Props {
  title: string;
  activePage: 'dona' | 'adopta' | 'conocenos';
}

const { title, activePage } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Peluditos Felices - Refugio animal en Mocha, Tungurahua, Ecuador. Adopta, dona y conoce nuestra labor." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <title>{title} | Peluditos Felices</title>
  </head>
  <body>
    <div class="grain-overlay"></div>

    <header>
      <nav>
        <a href="/dona" class="logo" aria-label="Peluditos Felices - Inicio">
          <span class="logo-paw">🐾</span>
          <span class="logo-text">Peluditos Felices</span>
        </a>
        <div class="nav-links">
          <a href="/dona" class:list={["nav-link", { active: activePage === 'dona' }]}>Dona</a>
          <a href="/adopta" class:list={["nav-link", { active: activePage === 'adopta' }]}>Adopta</a>
          <a href="/conocenos" class:list={["nav-link", { active: activePage === 'conocenos' }]}>Conocenos</a>
        </div>
        <a href="https://wa.me/593962041500" class="nav-cta" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <div class="footer-brand">
          <span class="footer-paw">🐾</span>
          <div>
            <p class="footer-name">Peluditos Felices</p>
            <p class="footer-location">Mocha, Tungurahua, Ecuador</p>
          </div>
        </div>
        <div class="footer-social">
          <a href="https://www.facebook.com/share/1J9vugpP9X/?mibextid=wwXIfr" target="_blank" aria-label="Facebook" class="social-link">
            <img src="/assets/icons/social/facebook.svg" alt="" width="28" height="28" />
          </a>
          <a href="https://www.instagram.com/peluditos_paw_patrol_refugio?igsh=d3B1cHM5MW5ldjMy" target="_blank" aria-label="Instagram" class="social-link">
            <img src="/assets/icons/social/instagram.svg" alt="" width="28" height="28" />
          </a>
        </div>
        <div class="footer-contact">
          <a href="https://wa.me/593962041500" class="footer-whatsapp" target="_blank" rel="noopener noreferrer">
            <img src="/assets/icons/social/wp.svg" alt="" width="24" height="24" />
            +593 962 041 500
          </a>
          <p class="footer-email">peluditosfelices@gmail.com</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Peluditos Felices. Todos los derechos reservados.</p>
      </div>
    </footer>

    <style is:global>
      :root {
        --orange: #fd7e14;
        --orange-dark: #e06b00;
        --orange-light: #fff0e0;
        --cream: #fdf6ee;
        --cream-dark: #f5e6d0;
        --brown-dark: #2d1810;
        --brown: #5c3a24;
        --brown-light: #8b6548;
        --green: #4a7c59;
        --green-light: #e8f5e9;
        --white: #ffffff;
        --shadow-sm: 0 1px 3px rgba(45, 24, 16, 0.08);
        --shadow-md: 0 4px 16px rgba(45, 24, 16, 0.1);
        --shadow-lg: 0 8px 32px rgba(45, 24, 16, 0.12);
        --radius-sm: 8px;
        --radius-md: 16px;
        --radius-lg: 24px;
        --radius-xl: 32px;
      }

      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: 'DM Sans', sans-serif;
        color: var(--brown-dark);
        background: var(--cream);
        line-height: 1.6;
        overflow-x: hidden;
        position: relative;
      }

      .grain-overlay {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9999;
        opacity: 0.03;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      }

      h1, h2, h3, h4 {
        font-family: 'Fraunces', serif;
        font-weight: 600;
        line-height: 1.2;
        color: var(--brown-dark);
      }

      a {
        text-decoration: none;
        color: inherit;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 24px;
      }

      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(24px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }

      .fade-up {
        animation: fadeInUp 0.7s ease-out both;
      }

      .fade-up-delay-1 { animation-delay: 0.1s; }
      .fade-up-delay-2 { animation-delay: 0.2s; }
      .fade-up-delay-3 { animation-delay: 0.3s; }
      .fade-up-delay-4 { animation-delay: 0.4s; }
    </style>

    <style>
      header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(253, 246, 238, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(45, 24, 16, 0.06);
      }

      nav {
        max-width: 1100px;
        margin: 0 auto;
        padding: 14px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'Fraunces', serif;
        font-weight: 700;
        font-size: 1.35rem;
        color: var(--brown-dark);
        transition: transform 0.2s ease;
      }

      .logo:hover {
        transform: scale(1.03);
      }

      .logo-paw {
        font-size: 1.5rem;
        filter: grayscale(0.2);
      }

      .nav-links {
        display: flex;
        gap: 4px;
      }

      .nav-link {
        padding: 8px 18px;
        border-radius: 100px;
        font-weight: 500;
        font-size: 0.95rem;
        color: var(--brown);
        transition: all 0.25s ease;
      }

      .nav-link:hover {
        background: var(--orange-light);
        color: var(--orange-dark);
      }

      .nav-link.active {
        background: var(--orange);
        color: var(--white);
        font-weight: 600;
      }

      .nav-cta {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 18px;
        border-radius: 100px;
        background: #25d366;
        color: var(--white);
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.25s ease;
        box-shadow: 0 2px 8px rgba(37, 211, 102, 0.3);
      }

      .nav-cta:hover {
        background: #20bd5a;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(37, 211, 102, 0.35);
      }

      footer {
        background: var(--brown-dark);
        color: rgba(255, 255, 255, 0.8);
        margin-top: 80px;
        position: relative;
        overflow: hidden;
      }

      footer::before {
        content: '';
        position: absolute;
        top: -40px;
        left: 0;
        right: 0;
        height: 80px;
        background: var(--cream);
        border-radius: 0 0 50% 50%;
      }

      .footer-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 60px 24px 32px;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 40px;
        align-items: start;
      }

      .footer-brand {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .footer-paw {
        font-size: 2rem;
      }

      .footer-name {
        font-family: 'Fraunces', serif;
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--white);
      }

      .footer-location {
        font-size: 0.85rem;
        opacity: 0.7;
      }

      .footer-social {
        display: flex;
        gap: 12px;
        justify-self: center;
      }

      .social-link {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.9);
        transition: all 0.25s ease;
      }

      .social-link:hover {
        background: #ffffff;
        transform: translateY(-2px);
      }

      .social-link img {
        width: 24px;
        height: 24px;
      }

      .footer-contact {
        text-align: right;
      }

      .footer-whatsapp {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #25d366;
        font-weight: 600;
        font-size: 0.95rem;
        transition: opacity 0.2s;
      }

      .footer-whatsapp:hover {
        opacity: 0.8;
      }

      .footer-whatsapp img {
        filter: none;
        opacity: 1;
      }

      .footer-email {
        margin-top: 6px;
        font-size: 0.85rem;
        opacity: 0.6;
      }

      .footer-bottom {
        max-width: 1100px;
        margin: 0 auto;
        padding: 16px 24px;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        text-align: center;
        font-size: 0.8rem;
        opacity: 0.5;
      }

      @media (max-width: 768px) {
        nav {
          flex-wrap: wrap;
          justify-content: space-between;
          gap: 10px;
        }

        .logo {
          font-size: 1.05rem;
          min-width: 0;
        }

        .logo-paw {
          font-size: 1.2rem;
        }

        .nav-cta {
          order: 2;
          padding: 6px 12px;
          font-size: 0.8rem;
        }

        .nav-cta svg {
          width: 14px;
          height: 14px;
        }

        .nav-links {
          order: 3;
          width: 100%;
          justify-content: center;
        }

        .footer-inner {
          grid-template-columns: 1fr;
          text-align: center;
          gap: 24px;
        }

        .footer-brand {
          justify-content: center;
        }

        .footer-social {
          justify-self: center;
        }

        .footer-contact {
          text-align: center;
        }
      }
    </style>
  </body>
</html>
