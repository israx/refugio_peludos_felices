---
import Layout from '../layouts/Layout.astro';

const animals = [
  {
    name: 'Paquito',
    age: '6 meses',
    image: '/assets/animals/perro.png',
    type: 'Perro',
    description: 'Paquito es un cachorrito lleno de energia y amor. Busca una familia que le de todo el carino que merece.',
  },
  {
    name: 'Rumino',
    age: '8 meses',
    image: '/assets/animals/gato.png',
    type: 'Gato',
    description: 'Rumino es un gatito curioso y tranquilo. Le encanta explorar y dormir en lugares calentitos.',
  },
];
---

<Layout title="Adopta" activePage="adopta">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-text fade-up">
        <span class="hero-badge">Dale un hogar</span>
        <h1>Encuentra a tu nuevo <br /><em>mejor amigo</em></h1>
        <p class="hero-subtitle">
          Contamos con mas de 20 animalitos entre perritos y gatitos
          esperando por una familia que los ame.
        </p>
      </div>
    </div>
    <div class="hero-wave">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
        <path d="M0,60 C240,120 480,0 720,60 C960,120 1200,0 1440,60 L1440,120 L0,120 Z" fill="var(--white)"/>
      </svg>
    </div>
  </section>

  <!-- Animal Cards -->
  <section class="section-animals">
    <div class="container">
      <div class="animals-grid">
        {animals.map((animal, i) => (
          <article class={`animal-card fade-up fade-up-delay-${i + 1}`}>
            <div class="animal-image-wrap">
              <img src={animal.image} alt={`${animal.name} - ${animal.type} en adopcion`} width="400" height="400" loading="lazy" />
              <span class="animal-type-badge">{animal.type}</span>
            </div>
            <div class="animal-info">
              <div class="animal-header">
                <h3>{animal.name}</h3>
                <span class="animal-age">{animal.age}</span>
              </div>
              <p>{animal.description}</p>
              <a
                href={`https://wa.me/593962041500?text=Hola%2C%20me%20interesa%20adoptar%20a%20${animal.name}`}
                class="adopt-btn"
                target="_blank"
                rel="noopener noreferrer"
              >
                Quiero adoptar a {animal.name}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-cta">
    <div class="container">
      <div class="cta-card fade-up">
        <div class="cta-paws">🐾</div>
        <h2>Muchos mas peluditos te esperan</h2>
        <p>
          Tenemos mas de 20 animalitos entre perritos y gatos. Comunicate a
          nuestro WhatsApp para conocerlos a todos y encontrar a tu companero ideal.
        </p>
        <a href="https://wa.me/593962041500?text=Hola%2C%20quiero%20conocer%20los%20animalitos%20en%20adopcion" class="cta-btn" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Ver todos los animalitos
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(165deg, var(--green-light) 0%, var(--cream) 60%);
    padding: 60px 0 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -80px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(74, 124, 89, 0.06) 0%, transparent 70%);
  }

  .hero-badge {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(74, 124, 89, 0.12);
    color: var(--green);
    border-radius: 100px;
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    margin-bottom: 16px;
  }

  .hero h1 {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    margin-bottom: 16px;
  }

  .hero h1 em {
    color: var(--green);
    font-style: italic;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--brown-light);
    max-width: 520px;
    margin: 0 auto 20px;
    line-height: 1.7;
  }

  .hero-wave {
    margin-top: -1px;
  }

  .hero-wave svg {
    display: block;
    width: 100%;
    height: 80px;
  }

  /* Animals */
  .section-animals {
    background: var(--white);
    padding: 50px 0 70px;
  }

  .animals-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 840px;
    margin: 0 auto;
  }

  .animal-card {
    background: var(--cream);
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid rgba(45, 24, 16, 0.05);
    transition: all 0.3s ease;
  }

  .animal-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .animal-image-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .animal-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .animal-card:hover .animal-image-wrap img {
    transform: scale(1.05);
  }

  .animal-type-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 4px 12px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    border-radius: 100px;
    font-weight: 600;
    font-size: 0.75rem;
    color: var(--brown-dark);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .animal-info {
    padding: 22px 24px 26px;
  }

  .animal-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .animal-header h3 {
    font-size: 1.4rem;
  }

  .animal-age {
    font-size: 0.85rem;
    color: var(--brown-light);
    font-weight: 500;
  }

  .animal-info p {
    color: var(--brown-light);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 18px;
  }

  .adopt-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    background: var(--green);
    color: var(--white);
    font-weight: 700;
    font-size: 0.85rem;
    border-radius: 100px;
    transition: all 0.3s ease;
    box-shadow: 0 3px 12px rgba(74, 124, 89, 0.25);
  }

  .adopt-btn:hover {
    background: #3d6a4b;
    transform: translateY(-1px);
    box-shadow: 0 5px 18px rgba(74, 124, 89, 0.3);
  }

  /* CTA */
  .section-cta {
    padding: 40px 0;
  }

  .cta-card {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    background: linear-gradient(145deg, #fff8f0, var(--orange-light));
    border: 1px solid rgba(253, 126, 20, 0.12);
    border-radius: var(--radius-xl);
    padding: 48px 36px;
    position: relative;
    overflow: hidden;
  }

  .cta-card::before {
    content: '';
    position: absolute;
    top: -60px;
    right: -60px;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: rgba(253, 126, 20, 0.06);
  }

  .cta-paws {
    font-size: 2.5rem;
    margin-bottom: 12px;
  }

  .cta-card h2 {
    font-size: 1.6rem;
    margin-bottom: 12px;
  }

  .cta-card p {
    color: var(--brown-light);
    line-height: 1.7;
    max-width: 440px;
    margin: 0 auto 24px;
    font-size: 0.95rem;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: #25d366;
    color: var(--white);
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 100px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 16px rgba(37, 211, 102, 0.3);
  }

  .cta-btn:hover {
    background: #20bd5a;
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(37, 211, 102, 0.35);
  }

  @media (max-width: 768px) {
    .animals-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
    }
  }
</style>
