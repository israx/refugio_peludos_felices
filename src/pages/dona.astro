---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dona" activePage="dona">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-content fade-up">
        <span class="hero-badge">Cada aporte cuenta</span>
        <h1>Ayudanos a seguir <br /><em>salvando vidas</em></h1>
        <p class="hero-subtitle">
          Tu donacion nos permite alimentar, curar y cuidar a mas de 20 peluditos
          que esperan un hogar lleno de amor.
        </p>
        <a href="https://wa.me/593962041500" class="btn-primary" target="_blank" rel="noopener noreferrer">
          Quiero donar
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="hero-visual fade-up fade-up-delay-2">
        <div class="hero-blob">
          <img src="/assets/animals/perro.png" alt="Perrito esperando un hogar" width="380" height="380" />
        </div>
      </div>
    </div>
    <div class="hero-wave">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
        <path d="M0,80 C360,120 720,0 1080,60 C1260,90 1380,100 1440,80 L1440,120 L0,120 Z" fill="var(--white)"/>
      </svg>
    </div>
  </section>

  <!-- Bank Transfers -->
  <section class="section-bank">
    <div class="container">
      <div class="section-header fade-up">
        <span class="section-icon">🏦</span>
        <h2>Transferencias bancarias</h2>
        <p>Cuentas de ahorros a nombre de <strong>Peludos Felices</strong></p>
      </div>

      <div class="bank-cards">
        <div class="bank-card fade-up fade-up-delay-1">
          <div class="bank-card-header">
            <span class="bank-logo">BP</span>
            <div>
              <h3>Banco Pichincha</h3>
              <span class="bank-type">Cuenta de ahorros</span>
            </div>
          </div>
          <div class="bank-number">
            <span>000000</span>
            <button class="copy-btn" data-copy="000000" aria-label="Copiar numero de cuenta">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            </button>
          </div>
        </div>

        <div class="bank-card fade-up fade-up-delay-2">
          <div class="bank-card-header">
            <span class="bank-logo pacifico">BPa</span>
            <div>
              <h3>Banco Pacifico</h3>
              <span class="bank-type">Cuenta de ahorros</span>
            </div>
          </div>
          <div class="bank-number">
            <span>1051611837</span>
            <button class="copy-btn" data-copy="1051611837" aria-label="Copiar numero de cuenta">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            </button>
          </div>
        </div>
      </div>

      <div class="bank-info fade-up fade-up-delay-3">
        <div class="info-chip">
          <span class="info-label">RUC</span>
          <span class="info-value">1792329930001</span>
        </div>
        <div class="info-chip">
          <span class="info-label">Email</span>
          <span class="info-value">betzabeth.2891@gmail.com</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Other ways to help -->
  <section class="section-help">
    <div class="container">
      <div class="help-grid">
        <div class="help-card food fade-up">
          <div class="help-card-icon">🍖</div>
          <h3>Alimento</h3>
          <p>
            Los animalitos necesitan de croquetas, arrocillo y otros alimentos.
            Esto puede ser entregado en la ciudad de <strong>Ambato</strong>.
          </p>
          <a href="https://wa.me/593962041500?text=Hola%2C%20quiero%20donar%20alimento" class="help-link" target="_blank" rel="noopener noreferrer">
            Coordinar entrega
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="help-card vet fade-up fade-up-delay-1">
          <div class="help-card-icon">🩺</div>
          <h3>Veterinaria</h3>
          <p>
            Necesitamos veterinarios para chequeos rutinarios, esterilizaciones
            y cuidado medico general de nuestros peluditos.
          </p>
          <a href="https://wa.me/593962041500?text=Hola%2C%20soy%20veterinario%20y%20quiero%20ayudar" class="help-link" target="_blank" rel="noopener noreferrer">
            Ofrecer ayuda
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(165deg, var(--orange-light) 0%, var(--cream) 60%);
    padding: 60px 0 0;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -120px;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(253, 126, 20, 0.08) 0%, transparent 70%);
  }

  .hero .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .hero-badge {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(253, 126, 20, 0.12);
    color: var(--orange-dark);
    border-radius: 100px;
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    margin-bottom: 16px;
  }

  .hero h1 {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    margin-bottom: 16px;
  }

  .hero h1 em {
    color: var(--orange);
    font-style: italic;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--brown-light);
    max-width: 440px;
    margin-bottom: 28px;
    line-height: 1.7;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: var(--orange);
    color: var(--white);
    font-weight: 700;
    font-size: 1rem;
    border-radius: 100px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 16px rgba(253, 126, 20, 0.35);
  }

  .btn-primary:hover {
    background: var(--orange-dark);
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(253, 126, 20, 0.4);
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .hero-blob {
    width: 340px;
    height: 340px;
    border-radius: 60% 40% 50% 50% / 50% 60% 40% 50%;
    overflow: hidden;
    background: var(--orange);
    box-shadow: 0 20px 60px rgba(253, 126, 20, 0.25);
    animation: blobMorph 8s ease-in-out infinite;
  }

  .hero-blob img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @keyframes blobMorph {
    0%, 100% { border-radius: 60% 40% 50% 50% / 50% 60% 40% 50%; }
    25% { border-radius: 50% 50% 40% 60% / 60% 40% 50% 50%; }
    50% { border-radius: 40% 60% 50% 50% / 50% 50% 60% 40%; }
    75% { border-radius: 50% 40% 60% 50% / 40% 50% 50% 60%; }
  }

  .hero-wave {
    margin-top: -1px;
  }

  .hero-wave svg {
    display: block;
    width: 100%;
    height: 80px;
  }

  /* Bank Section */
  .section-bank {
    background: var(--white);
    padding: 60px 0 70px;
  }

  .section-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .section-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 12px;
  }

  .section-header h2 {
    font-size: 1.8rem;
    margin-bottom: 8px;
  }

  .section-header p {
    color: var(--brown-light);
    font-size: 1rem;
  }

  .bank-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 700px;
    margin: 0 auto;
  }

  .bank-card {
    background: var(--cream);
    border: 1px solid rgba(45, 24, 16, 0.06);
    border-radius: var(--radius-lg);
    padding: 24px;
    transition: all 0.3s ease;
  }

  .bank-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .bank-card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .bank-logo {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: linear-gradient(135deg, #0033a0, #004ecb);
    color: var(--white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 0.75rem;
    letter-spacing: -0.02em;
  }

  .bank-logo.pacifico {
    background: linear-gradient(135deg, #003d7a, #0066cc);
  }

  .bank-card h3 {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
  }

  .bank-type {
    font-size: 0.8rem;
    color: var(--brown-light);
  }

  .bank-number {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--white);
    border-radius: var(--radius-sm);
    padding: 12px 16px;
    font-family: 'DM Sans', monospace;
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: 0.05em;
    color: var(--brown-dark);
  }

  .copy-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: 6px;
    color: var(--brown-light);
    transition: all 0.2s ease;
  }

  .copy-btn:hover {
    background: var(--orange-light);
    color: var(--orange);
  }

  .bank-info {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-top: 24px;
    flex-wrap: wrap;
  }

  .info-chip {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--cream);
    border-radius: 100px;
    font-size: 0.85rem;
  }

  .info-label {
    font-weight: 700;
    color: var(--orange);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .info-value {
    color: var(--brown);
  }

  /* Help Section */
  .section-help {
    padding: 60px 0 40px;
  }

  .help-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 800px;
    margin: 0 auto;
  }

  .help-card {
    border-radius: var(--radius-xl);
    padding: 36px 30px;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .help-card:hover {
    transform: translateY(-4px);
  }

  .help-card.food {
    background: linear-gradient(145deg, #fff8f0, #ffedd5);
    border: 1px solid rgba(253, 126, 20, 0.15);
  }

  .help-card.vet {
    background: linear-gradient(145deg, #f0fdf4, #dcfce7);
    border: 1px solid rgba(74, 124, 89, 0.15);
  }

  .help-card-icon {
    font-size: 2.4rem;
    margin-bottom: 16px;
  }

  .help-card h3 {
    font-size: 1.3rem;
    margin-bottom: 10px;
  }

  .help-card p {
    color: var(--brown-light);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .help-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--orange);
    transition: gap 0.2s ease;
  }

  .help-card.vet .help-link {
    color: var(--green);
  }

  .help-link:hover {
    gap: 10px;
  }

  @media (max-width: 768px) {
    .hero .container {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-blob {
      width: 260px;
      height: 260px;
    }

    .bank-cards {
      grid-template-columns: 1fr;
    }

    .help-grid {
      grid-template-columns: 1fr;
    }

    .btn-primary {
      margin: 0 auto;
    }
  }
</style>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = (btn as HTMLElement).dataset.copy;
      if (text) {
        navigator.clipboard.writeText(text);
        const svg = btn.innerHTML;
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>';
        setTimeout(() => { btn.innerHTML = svg; }, 1500);
      }
    });
  });
</script>
